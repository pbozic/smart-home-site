# ---------------------------------------------------------------------------
# Sanity configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values to connect a Sanity
# project. Leave them empty to rely on the LOCAL CONTENT FALLBACK — the site
# builds and exports its static pages from `src/content/*` without any Sanity
# project configured.

# Public (safe to expose to the browser — NEXT_PUBLIC_ prefix).
# Sanity project id and dataset, used by the read-only client + Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# API version pin (Sanity recommends a fixed date so responses don't shift).
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# ---------------------------------------------------------------------------
# Server-only secret — DO NOT add a NEXT_PUBLIC_ prefix.
# ---------------------------------------------------------------------------
# Write token used by the server-side savePuckData() action to persist Puck
# layout JSON back to Sanity. It grants write access, so it must NEVER reach
# the client bundle. Keeping it WITHOUT the NEXT_PUBLIC_ prefix ensures Next.js
# only exposes it to server code and never inlines it into client JS.
SANITY_API_WRITE_TOKEN=
